# ========================================
# CRM Production Environment Variables
# ========================================
# Copy this file to .env and update values:
#   cp .env.prod.example .env
# ========================================

# Database
DB_NAME=crm
DB_USER=crm_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_STRONG_PASSWORD

# JWT - Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# Server Public URL (your server IP, no trailing slash)
PUBLIC_URL=http://YOUR_SERVER_IP
CORS_ORIGIN=http://YOUR_SERVER_IP

# Gmail SMTP (for password reset and TOTP emails)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Green API (WhatsApp) — see https://console.green-api.com
# GREEN_API_URL is optional; auto-derived from the instance id if blank
# (e.g. instance 7103 → https://7103.api.green-api.com).
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
GREEN_API_URL=

# TimeTable SSO — HMAC secret used to sign one-click admin/user links from
# OpsHub into the TimeTable microservice. Generate with:
#   openssl rand -hex 32
# Must be identical for the api and timetable services.
TIMETABLE_SSO_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
