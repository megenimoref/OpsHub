PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=crm_password_123

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173

# Green API (WhatsApp) — values are per-instance, taken from the
# Green API control panel. GREEN_API_URL is optional: if omitted the
# code derives the URL from the instance id
# (https://<idInstance>.api.green-api.com).
GREEN_API_ID_INSTANCE=
GREEN_API_TOKEN_INSTANCE=
GREEN_API_URL=
